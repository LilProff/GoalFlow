# ── AI (Required) ──────────────────────────────────────────────────────────
# OpenRouter API key — free signup at https://openrouter.ai
# Model used: google/gemini-2.0-flash-exp:free (10 RPM, 200 RPD free)
VITE_OPENROUTER_API_KEY="or-..."

# ── Cloud Sync (Optional) ───────────────────────────────────────────────────
# Supabase project URL and anon key — free at https://supabase.com
# If not set, app works fully offline with localStorage only.
VITE_SUPABASE_URL="https://xxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# ── Legacy (no longer used) ─────────────────────────────────────────────────
# GEMINI_API_KEY="..."
